#9.3 解析 geNomad / IntegronFinder / ISEScan 结果
#其实contig的mge结果就包含了MAG的mge结果，我们后期通过构建对照表关联起来，不必特意做MAG的mge了
#合并每个样本contig的mge结果
mkdir -p 13_tables/mge_parsed

for sample in $(cut -f1 00_meta/samples.tsv | tail -n +2); do
    python parse_genomad.py \
      -i 11_mge/genomad/${sample}/final.contigs_summary \
      -o 13_tables/mge_parsed/${sample}.genomad.tsv

    python parse_integronfinder.py \
      -i 11_mge/integron/${sample} \
      -o 13_tables/mge_parsed/${sample}.integron.tsv

    python parse_isescan.py \
      -i 11_mge/isescan/${sample}/clean_fa \
      -o 13_tables/mge_parsed/${sample}.isescan.tsv \
      --detail 13_tables/mge_parsed/${sample}.isescan_detail.tsv

    python merge_mge_tables.py \
      --genomad 13_tables/mge_parsed/${sample}.genomad.tsv \
      --integron 13_tables/mge_parsed/${sample}.integron.tsv \
      --isescan 13_tables/mge_parsed/${sample}.isescan.tsv \
      -o 13_tables/mge_parsed/${sample}.contig_mge.tsv
done

#合并所有样本contig的mge结果，得到contig X MGE对照表
python merge_all_contig_mge.py \
  -i 13_tables/mge_parsed \
  -o 13_tables/all_samples.contig_mge.tsv

