#9. 生成核心关联表
#你最终至少要做 4 张核心表：
#sample x MAG abundance
#MAG x ARG
#contig x ARG
#contig x MGE
#再整合成：
#MAG x MGE-associated ARG
#下面是基本流程：

#9.1 合并 MAG 层 ARG 注释
out="13_tables/mag_arg.tsv"

# 写表头
printf "MAG\tProtein_id\tElement_symbol\tElement_name\tScope\tType\tSubtype\tClass\tSubclass\tMethod\n" > "$out"

for f in 10_annotation/arg/amrfinder/*.tsv; do
    [ -e "$f" ] || continue

    mag=$(basename "$f" .tsv)

    # 如果文件行数 <= 1，说明只有表头或空文件，跳过
    nlines=$(wc -l < "$f")
    if [ "$nlines" -le 1 ]; then
        echo "[INFO] Skip empty/no-hit file: $f"
        continue
    fi

    # 提取需要的列：
    # 1  Protein id
    # 2  Element symbol
    # 3  Element name
    # 4  Scope
    # 5  Type
    # 6  Subtype
    # 7  Class
    # 8  Subclass
    # 9  Method
    awk -F'\t' -v OFS='\t' -v m="$mag" '
        NR>1 && $1!="" {
            print m, $1, $2, $3, $4, $5, $6, $7, $8, $9
        }
    ' "$f" >> "$out"

done

echo "[INFO] Output written to: $out"

#9.2 合并 contig 层 ARG 注释
echo -e "Sample\tContig\tProtein\tARG\tElement_name\tType\tSubtype\tClass\tSubclass\tMethod" > 13_tables/contig_arg.tsv

for f in 12_contig_level/arg/*.tsv; do
    sample=$(basename "$f" .tsv)

    awk -F'\t' -v s="$sample" 'NR>1{
        prot=$1
        contig=prot
        sub(/_[0-9]+$/, "", contig)   # 去掉最后一个ORF编号，如 _6

        print s"\t"contig"\t"$1"\t"$2"\t"$3"\t"$5"\t"$6"\t"$7"\t"$8"\t"$9
    }' OFS='\t' "$f" >> 13_tables/contig_arg.tsv
done

wait

awk -F'\t' '
BEGIN{
    OFS="\t"
}
NR==1{next}
{
    key=$1"\t"$2   # Sample + Contig
    sample[key]=$1
    contig[key]=$2

    if(arglist[key]==""){
        arglist[key]=$4
    } else if(arglist[key] !~ "(^|;)"$4"(;|$)"){
        arglist[key]=arglist[key]";"$4
    }

    if(classlist[key]==""){
        classlist[key]=$7
    } else if(classlist[key] !~ "(^|;)"$7"(;|$)"){
        classlist[key]=classlist[key]";"$7
    }

    count[key]++
}
END{
    print "Sample","Contig","ARG_count","ARG_list","Class_list"
    for(k in count){
        print sample[k],contig[k],count[k],arglist[k],classlist[k]
    }
}' 13_tables/contig_arg.tsv > 13_tables/contig_arg_summary.tsv

#有时候，受限于amrfinder数据库的原因，用这个单一流程做出来的结果不太理想：

