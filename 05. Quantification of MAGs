#3. MAG 丰度矩阵：reads 回贴到 non-redundant MAG catalog
#3.1 合并 catalog
cat 07_drep/out/dereplicated_genomes/*.fa > 07_drep/mag_catalog.fa
bowtie2-build 07_drep/mag_catalog.fa 07_drep/mag_catalog

#3.2 用 CoverM 计算每个样本对每个 MAG 的覆盖/相对丰度
conda activate coverm
mkdir -p 09_mapping/coverm

while IFS=$'\t' read -r sample host site season sex age r1 r2; do
  coverm genome \
    --coupled "03_host_removed/${sample}_R1.fq.gz" "03_host_removed/${sample}_R2.fq.gz" \
    --genome-fasta-directory 07_drep/out/dereplicated_genomes \
    --methods relative_abundance trimmed_mean covered_fraction mean \
    --min-read-aligned-percent 75 \
    --min-read-percent-identity 95 \
    --threads 24 \
    > "09_mapping/coverm/${sample}.tsv"
done < <(tail -n +2 00_meta/samples.tsv)

conda deactivate
