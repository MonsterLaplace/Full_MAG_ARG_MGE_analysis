#6. VFDB 注释
conda activate diamond
#下载vfdb数据库
wget https://www.mgc.ac.cn/VFs/Down/VFDB_setB_pro.fas.gz
diamond makedb --in VFDB_setB_pro.fas -d VFDB

mkdir -p 10_annotation/vfdb

for faa in 10_annotation/proteins/*.faa; do
  id=$(basename "$faa" .faa)
  diamond blastp \
    -d /path/to/VFDB.dmnd \
    -q "$faa" \
    -o "10_annotation/vfdb/${id}.tsv" \
    -e 1e-10 -k 1 -p 8 \
    --id 70 --query-cover 70
done
conda deactivate
